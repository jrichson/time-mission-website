---
import analyticsLabels from '../data/site/analytics-labels.json';
import { getSeoForRoute } from '../lib/seo/catalog';
import locationsData from '../../data/locations.json';

interface Props {
    canonicalPath: string;
    title?: string;
    description?: string;
    ogImage?: string;
    twitterImage?: string;
    robots?: string;
}

const {
    canonicalPath,
    title: titleOverride,
    description: descOverride,
    ogImage: ogOverride,
    twitterImage: twOverride,
    robots: robotsOverride,
} = Astro.props;

const seo = getSeoForRoute(canonicalPath);
const title = titleOverride ?? seo.title;
const description = descOverride ?? seo.description;
const canonicalUrl = seo.canonicalUrl;
const og = ogOverride ?? seo.ogImage;
const tw = twOverride ?? seo.twitterImage;
const robotsValue = robotsOverride ?? seo.robots;

const gtmContainerId = String(import.meta.env.PUBLIC_GTM_CONTAINER_ID || '').trim();
const sgtmContainerUrl = String(import.meta.env.PUBLIC_SGTM_CONTAINER_URL || '').trim().replace(/\/+$/, '');
const sgtmCollectPath = String(import.meta.env.PUBLIC_SGTM_COLLECT_PATH || '/g/collect').trim();

type ConsentProfile = 'eu_strict' | 'us_open' | 'global_strict';
type ConsentDefaults = {
    ad_storage: 'granted' | 'denied';
    analytics_storage: 'granted' | 'denied';
    ad_user_data: 'granted' | 'denied';
    ad_personalization: 'granted' | 'denied';
    functionality_storage: 'granted';
    security_storage: 'granted';
    wait_for_update: number;
};

const locationEntries = ((locationsData as { locations?: Array<{ slug?: string; region?: string }> }).locations || []);
const pathRegionMap = new Map<string, string>();
for (const entry of locationEntries) {
    if (!entry?.slug || !entry?.region) continue;
    pathRegionMap.set(`/${entry.slug}`, String(entry.region));
}
const currentRegion = pathRegionMap.get(canonicalPath) || '';
const consentProfile: ConsentProfile =
    currentRegion === 'europe' ? 'eu_strict' : currentRegion === 'us' ? 'us_open' : 'global_strict';
const consentDefaults: ConsentDefaults =
    consentProfile === 'us_open'
        ? {
              ad_storage: 'granted',
              analytics_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
              functionality_storage: 'granted',
              security_storage: 'granted',
              wait_for_update: 500,
          }
        : {
              ad_storage: 'denied',
              analytics_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
              functionality_storage: 'granted',
              security_storage: 'granted',
              wait_for_update: 500,
          };
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>{title}</title>
<!-- SEO META -->
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={robotsValue} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={og} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={tw} />
<link rel="icon" type="image/png" href="/assets/logo/TM_Favicon.png" />
<script is:inline define:vars={{ analyticsLabels }}>window.__TM_ANALYTICS_LABELS__ = analyticsLabels;</script>
<script is:inline define:vars={{ gtmContainerId, sgtmContainerUrl, sgtmCollectPath, consentDefaults, consentProfile }}>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
        dataLayer.push(arguments);
    }
    window.gtag = gtag;
    window.__TM_CONSENT_STATE__ = Object.assign({}, consentDefaults);
    gtag('consent', 'default', consentDefaults);
    // Optional server-side GTM metadata for container-side routing decisions.
    window.__TM_TAGGING_CONFIG__ = {
        web_container_id: gtmContainerId || '',
        sgtm_container_url: sgtmContainerUrl || '',
        sgtm_collect_path: sgtmCollectPath || '/g/collect',
        mode: sgtmContainerUrl ? 'web_and_sgtm' : 'web_only',
        consent_profile: consentProfile,
    };
    dataLayer.push({
        event: 'tm_tagging_config',
        tagging_mode: window.__TM_TAGGING_CONFIG__.mode,
        tagging_server_url: window.__TM_TAGGING_CONFIG__.sgtm_container_url,
        tagging_server_collect_path: window.__TM_TAGGING_CONFIG__.sgtm_collect_path,
        web_gtm_container_id: window.__TM_TAGGING_CONFIG__.web_container_id,
        consent_profile: window.__TM_TAGGING_CONFIG__.consent_profile,
    });
</script>
{gtmContainerId ? (
    <>
        <script is:inline define:vars={{ gtmContainerId }}>
            (function (w, d, s, l, i) {
                w[l] = w[l] || [];
                w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
                var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s),
                    dl = l != 'dataLayer' ? '&l=' + l : '';
                j.async = true;
                j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
                f.parentNode.insertBefore(j, f);
            })(window, document, 'script', 'dataLayer', gtmContainerId);
        </script>
        <noscript>
            <iframe
                src={`https://www.googletagmanager.com/ns.html?id=${gtmContainerId}`}
                height="0"
                width="0"
                style="display:none;visibility:hidden"
                aria-hidden="true"
                tabindex="-1"
            />
        </noscript>
    </>
) : null}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="font" href="/assets/fonts/MonumentExtended-Regular.otf" type="font/otf" crossorigin />
<link rel="preload" as="font" href="/assets/fonts/MonumentExtended-Ultrabold.otf" type="font/otf" crossorigin />
<!-- Plain stylesheet (no inline onload): script-src-attr 'none' in _headers blocks handler attributes. -->
<link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Orbitron:wght@400;500;600;700;800;900&display=swap"
/>
<link rel="stylesheet" href="/css/variables.css" />
<link rel="stylesheet" href="/css/base.css" />
<link rel="stylesheet" href="/css/nav.css?v=17" />
