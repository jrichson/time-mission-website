---
/**
 * Full-width footer matching legacy `footer-grid` pages (index, FAQ, contact, etc.).
 * Keeps structure in sync with `src/partials/faq-footer.frag.txt`.
 */
const year = new Date().getFullYear();
---

<footer class="footer">
    <div class="footer-grid">
        <div class="footer-brand">
            <img src="/assets/logo/TM_Logo_White.svg" alt="Time Mission" />
            <p>
                A social gaming adventure where teams compete through immersive challenges across time and space.
            </p>
            <div class="footer-social">
                <a href="https://www.instagram.com/timemission/" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                        <circle cx="12" cy="12" r="4.5"></circle>
                        <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"></circle>
                    </svg>
                </a>
                <a href="https://www.tiktok.com/@timemissionhq" target="_blank" rel="noopener" aria-label="TikTok">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                        <path
                            d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78c.27 0 .54.04.8.1v-3.51a6.37 6.37 0 0 0-.8-.05A6.34 6.34 0 0 0 3.15 15.3a6.34 6.34 0 0 0 10.86 4.34A6.28 6.28 0 0 0 15.86 15V8.74a8.18 8.18 0 0 0 4.14 1.15V6.69h-.41z"
                        ></path>
                    </svg>
                </a>
                <a href="https://www.facebook.com/TimeMissionHQ/" target="_blank" rel="noopener" aria-label="Facebook">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                        <path
                            d="M24 12c0-6.627-5.373-12-12-12S0 5.373 0 12c0 5.99 4.388 10.954 10.125 11.854V15.47H7.078V12h3.047V9.356c0-3.007 1.792-4.668 4.533-4.668 1.312 0 2.686.235 2.686.235v2.953h-1.513c-1.49 0-1.956.927-1.956 1.874V12h3.328l-.532 3.47h-2.796v8.384C19.612 22.954 24 17.99 24 12z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
        <div class="footer-column">
            <h3 class="footer-title">EXPERIENCE</h3>
            <ul class="footer-links">
                <li><a href="/about">About</a></li>
                <li><a href="/missions">The Missions</a></li>
                <li><a href="/groups">Groups</a></li>
                <li><a href="/gift-cards">Gift Cards</a></li>
                <li><a href="/faq">FAQ</a></li>
            </ul>
        </div>
        <div class="footer-column">
            <h3 class="footer-title">INFO</h3>
            <ul class="footer-links">
                <li><a href="/contact">Contact Us</a></li>
                <li><a href="/waiver">Waiver</a></li>
                <li><a href="/licensing">Licensing</a></li>
            </ul>
        </div>
        <div class="footer-column footer-locations-column">
            <h3 class="footer-locations-title">LOCATIONS</h3>
            <div class="footer-locations-dropdown">
                <div class="footer-location-group">
                    <button type="button" class="footer-location-toggle">
                        United States
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 9l6 6 6-6"></path>
                        </svg>
                    </button>
                    <div class="footer-location-list">
                        <a href="/mount-prospect">Mount Prospect</a>
                        <a href="/philadelphia">Philadelphia</a>
                        <a href="/west-nyack">West Nyack</a>
                        <a href="/lincoln">Lincoln</a>
                        <a href="/houston">Houston</a>
                        <a href="/manassas">Manassas</a>
                        <a href="/orland-park" class="coming-soon"
                            >Orland Park <span class="coming-soon-tag">Coming Soon</span></a
                        >
                        <a href="/dallas" class="coming-soon">Dallas <span class="coming-soon-tag">Coming Soon</span></a>
                    </div>
                </div>
                <div class="footer-location-group">
                    <button type="button" class="footer-location-toggle">
                        Europe
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M6 9l6 6 6-6"></path>
                        </svg>
                    </button>
                    <div class="footer-location-list">
                        <a href="/antwerp">Antwerp</a>
                        <a href="/brussels" class="coming-soon"
                            >Brussels <span class="coming-soon-tag">Coming Soon</span></a
                        >
                    </div>
                </div>
            </div>
            <div class="footer-location-info" style="display: none;">
                <h5 class="footer-loc-name"></h5>
                <p class="footer-loc-address"></p>
                <a class="footer-loc-phone" href="tel:">
                    <span class="visually-hidden">Call your selected location</span>
                </a>
                <div class="footer-loc-hours"></div>
                <a class="footer-loc-map" href="#" target="_blank" rel="noopener">Get Directions →</a>
                <a class="footer-loc-change" href="#">Change Location</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <p class="footer-copyright">&copy; {year} Time Mission. All rights reserved.</p>
        <div class="footer-legal">
            <a href="/terms">Terms</a>
            <a href="/privacy">Privacy</a>
            <a href="/cookies">Cookies</a>
            <a href="/code-of-conduct">Code of Conduct</a>
            <a href="/accessibility">Accessibility</a>
            <a href="/licensing">Licensing</a>
            <button type="button" class="footer-link-button" data-cc="show-preferencesModal">
                Cookie Preferences
            </button>
        </div>
    </div>
</footer>

<style is:global>
    .footer-link-button {
        color: var(--gray);
        font-family: var(--body);
        font-size: 0.85rem;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
    }
    .footer-link-button:focus-visible {
        color: var(--white);
    }
    @media (hover: hover) {
        .footer-link-button:hover {
            color: var(--white);
        }
    }
    .footer-location-list a.coming-soon {
        opacity: 0.7;
        pointer-events: none;
        cursor: default;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    .footer-location-list .coming-soon-tag {
        font-size: 0.55rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: rgba(255, 107, 44, 0.18);
        color: #ff6b2c;
        padding: 0.15rem 0.5rem;
        border-radius: 100px;
        white-space: nowrap;
    }
</style>
