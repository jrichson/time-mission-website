---
interface Crumb {
    label: string;
    href?: string;
}
interface Props {
    items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
        {
            items.map((crumb) =>
                crumb.href ? (
                    <li>
                        <a href={crumb.href}>{crumb.label}</a>
                    </li>
                ) : (
                    <li aria-current="page">{crumb.label}</li>
                ),
            )
        }
    </ol>
</nav>
