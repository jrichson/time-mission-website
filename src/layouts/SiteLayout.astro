---
import SiteHead from '../components/SiteHead.astro';
import SiteNav from '../components/SiteNav.astro';
import MobileMenu from '../components/MobileMenu.astro';
import LocationOverlay from '../components/LocationOverlay.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TicketPanel from '../components/TicketPanel.astro';
import SiteScripts from '../components/SiteScripts.astro';

interface Props {
    canonicalPath: string;
    title?: string;
    description?: string;
    ogImage?: string;
    twitterImage?: string;
    robots?: string;
    bodyDataLocation?: string;
    bodyClass?: string;
    landingHead?: import('../lib/seo/catalog').LandingHeadInput | null;
}

const {
    title,
    description,
    canonicalPath,
    ogImage,
    twitterImage,
    robots,
    bodyDataLocation,
    bodyClass,
    landingHead,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <SiteHead
            canonicalPath={canonicalPath}
            title={title}
            description={description}
            ogImage={ogImage}
            twitterImage={twitterImage}
            robots={robots}
            landingHead={landingHead}
        />
        <slot name="head-extra" />
        <slot name="page-style" />
        <slot name="json-ld" />
    </head>
    <body class={bodyClass} data-location={bodyDataLocation}>
        <a class="skip-link" href="#main">Skip to main content</a>
        <header role="banner">
            <slot name="pre-nav" />
            <slot name="nav">
                <MobileMenu />
                <SiteNav />
                <LocationOverlay />
            </slot>
        </header>
        <main id="main" tabindex="-1">
            <slot />
        </main>
        <footer role="contentinfo">
            <slot name="footer">
                <SiteFooter />
            </slot>
        </footer>
        <TicketPanel />
        <SiteScripts />
        <slot name="after-site-scripts" />
    </body>
</html>
