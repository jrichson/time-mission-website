---
import SiteHead from '../components/SiteHead.astro';
import SiteNav from '../components/SiteNav.astro';
import MobileMenu from '../components/MobileMenu.astro';
import LocationOverlay from '../components/LocationOverlay.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TicketPanel from '../components/TicketPanel.astro';
import SiteScripts from '../components/SiteScripts.astro';

interface Props {
    canonicalPath: string;
    title?: string;
    description?: string;
    ogImage?: string;
    twitterImage?: string;
    robots?: string;
    bodyDataLocation?: string;
    bodyClass?: string;
}

const {
    title,
    description,
    canonicalPath,
    ogImage,
    twitterImage,
    robots,
    bodyDataLocation,
    bodyClass,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <SiteHead
            canonicalPath={canonicalPath}
            title={title}
            description={description}
            ogImage={ogImage}
            twitterImage={twitterImage}
            robots={robots}
        />
        <slot name="head-extra" />
        <slot name="page-style" />
        <slot name="json-ld" />
    </head>
    <body class={bodyClass} data-location={bodyDataLocation}>
        <slot name="pre-nav" />
        <slot name="nav">
            <MobileMenu />
            <SiteNav />
            <LocationOverlay />
        </slot>
        <slot />
        <slot name="footer">
            <SiteFooter />
        </slot>
        <TicketPanel />
        <SiteScripts />
        <slot name="after-site-scripts" />
    </body>
</html>
