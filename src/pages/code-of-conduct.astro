---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import legalCss from '../partials/legal-inline.raw.css.txt?raw';
import codeOfConductMain from '../partials/code-of-conduct-main.frag.txt?raw';
import { buildSimpleGraph, serializeGraph } from '../lib/schema/graph';

const ld = serializeGraph(
    buildSimpleGraph([
        { label: 'Home', href: '/' },
        { label: 'Code of Conduct', href: '/code-of-conduct' },
    ]),
);
const page = definePage({ canonicalPath: '/code-of-conduct' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyClass="has-noise"
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
    </Fragment>
    <Fragment slot="page-style">
        <style is:global set:html={legalCss}></style>
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={codeOfConductMain} />
</SiteLayout>
