---
import SiteLayout from '../layouts/SiteLayout.astro';
import indexCss from '../partials/index-inline.raw.css.txt?raw';
import indexMain from '../partials/index-main.frag.txt?raw';
import indexPrenav from '../partials/index-prenav.frag.txt?raw';
import indexAfter from '../partials/index-after.frag.txt?raw';
import { buildHomeGraph, serializeGraph } from '../lib/schema/graph';

const ld = serializeGraph(buildHomeGraph());
---

<SiteLayout
    canonicalPath="/"
>
    <Fragment slot="head-extra">
        <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" />
        <link rel="preload" as="font" href="/assets/fonts/MonumentExtended-Regular.otf" type="font/otf" crossorigin />
        <link rel="preload" as="font" href="/assets/fonts/MonumentExtended-Ultrabold.otf" type="font/otf" crossorigin />
        <link rel="stylesheet" href="/css/footer.css?v=2" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
    </Fragment>
    <Fragment slot="page-style">
        <style is:global set:html={indexCss}></style>
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <Fragment slot="pre-nav" set:html={indexPrenav} />
    <div class="home-main" set:html={indexMain} />
    <Fragment slot="after-site-scripts" set:html={indexAfter} />
</SiteLayout>
