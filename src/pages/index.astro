---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import indexMainRaw from '../partials/index-main.frag.txt?raw';
import { applyTmMediaBase } from '../lib/tm-media';
import indexPrenav from '../partials/index-prenav.frag.txt?raw';
import { buildHomeGraph, serializeGraph } from '../lib/schema/graph';

const ld = serializeGraph(buildHomeGraph());
const page = definePage({ canonicalPath: '/' });
const indexMain = applyTmMediaBase(indexMainRaw);
---

<SiteLayout
    canonicalPath={page.canonicalPath}
>
    <Fragment slot="head-extra">
        <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" fetchpriority="high" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="preload" as="style" href="/css/footer.css?v=3" onload="this.onload=null;this.rel='stylesheet'" />
        <link rel="preload" as="style" href="/css/ticket-panel.css" onload="this.onload=null;this.rel='stylesheet'" />
        <noscript><link rel="stylesheet" href="/css/footer.css?v=3" /></noscript>
        <noscript><link rel="stylesheet" href="/css/ticket-panel.css" /></noscript>
        <link rel="stylesheet" href="/css/page-index.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <Fragment slot="pre-nav" set:html={indexPrenav} />
    <div class="home-main" set:html={indexMain} />
    <Fragment slot="after-site-scripts">
        <script defer src="/js/page-index-after.js?v=1"></script>
    </Fragment>
</SiteLayout>
