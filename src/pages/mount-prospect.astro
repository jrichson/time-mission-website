---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import { allLocations } from '../data/locations';
import mountProspectCss from '../partials/mount-prospect-inline.raw.css.txt?raw';
import mountProspectMainRaw from '../partials/mount-prospect-main.frag.txt?raw';
import { applyTmMediaBase } from '../lib/tm-media';
import mountProspectAfter from '../partials/mount-prospect-after.frag.txt?raw';
import { buildLocationGraph, serializeGraph } from '../lib/schema/graph';

const mountProspect = allLocations.find((l) => l.slug === 'mount-prospect');
if (!mountProspect) throw new Error('mount-prospect missing from src/data/locations');

const ld = serializeGraph(
    buildLocationGraph('mount-prospect', '/mount-prospect', [
        { label: 'Home', href: '/' },
        { label: 'Locations', href: '/locations' },
        { label: mountProspect.shortName, href: '/mount-prospect' },
    ]),
);
const page = definePage({ canonicalPath: '/mount-prospect' });
const mountProspectMain = applyTmMediaBase(mountProspectMainRaw);
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyDataLocation={mountProspect.slug}
>
    <Fragment slot="head-extra">
        <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" />
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
    </Fragment>
    <Fragment slot="page-style">
        <style is:global set:html={mountProspectCss}></style>
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={mountProspectMain} />
    <Fragment slot="after-site-scripts" set:html={mountProspectAfter} />
</SiteLayout>
