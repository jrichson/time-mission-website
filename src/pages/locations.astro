---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import { allLocations } from '../data/locations';
import type { LocationRecord } from '../data/locations';
import { buildSimpleGraph, serializeGraph } from '../lib/schema/graph';

const US_ORDER = [
    'mount-prospect',
    'orland-park',
    'west-nyack',
    'philadelphia',
    'lincoln',
    'dallas',
    'houston',
    'manassas',
];
const EU_ORDER = ['antwerp', 'brussels'];

function orderLocs(region: string, slugOrder: string[]) {
    const pool = allLocations.filter((l) => l.region === region);
    return slugOrder.map((s) => pool.find((l) => l.slug === s)).filter(Boolean) as LocationRecord[];
}

const usLocs = orderLocs('us', US_ORDER);
const euLocs = orderLocs('europe', EU_ORDER);

function formatAddress(loc: LocationRecord) {
    const a = loc.address;
    const line = [a.line1, [a.city, a.state].filter(Boolean).join(', '), a.zip].filter(Boolean);
    return line.join(', ');
}

function stateBadge(loc: LocationRecord) {
    if (loc.address.state && loc.address.state.trim()) return loc.address.state;
    if (loc.region === 'europe') return 'BE';
    return '--';
}

const ld = serializeGraph(
    buildSimpleGraph([
        { label: 'Home', href: '/' },
        { label: 'Locations', href: '/locations' },
    ]),
);
const page = definePage({ canonicalPath: '/locations' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyClass="has-noise"
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
        <link rel="stylesheet" href="/css/page-locations.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>

    <main class="locations-page-main">
        <section class="hero">
            <div class="hero-content reveal">
                <div class="section-badge">Find Us</div>
                <h1 class="hero-title">OUR <span>LOCATIONS</span></h1>
                <p class="hero-subtitle">
                    Time Mission is expanding across the globe. Find a location near you and start your adventure.
                </p>
            </div>
        </section>

        <section class="locations-grid">
            <div class="locations-list">
                <div class="loc-group">
                    <div class="loc-group-title">United States</div>
                    {
                        usLocs.map((loc) => (
                            <a
                                href={`/${loc.slug}`}
                                class:list={[
                                    'loc-row',
                                    'reveal',
                                    { 'is-coming-soon': loc.status === 'coming-soon' },
                                ]}
                            >
                                <span class="loc-state">{stateBadge(loc)}</span>
                                <div class="loc-body">
                                    <div class="loc-name">
                                        {loc.shortName}
                                        {loc.status === 'coming-soon' ? (
                                            <span class="loc-coming-soon-tag">Coming Soon</span>
                                        ) : null}
                                    </div>
                                    <div class="loc-address">{formatAddress(loc)}</div>
                                </div>
                                <svg
                                    class="loc-arrow"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                >
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            </a>
                        ))
                    }
                </div>

                <div class="loc-group">
                    <div class="loc-group-title">Europe</div>
                    {
                        euLocs.map((loc) => (
                            <a
                                href={`/${loc.slug}`}
                                class:list={[
                                    'loc-row',
                                    'reveal',
                                    { 'is-coming-soon': loc.status === 'coming-soon' },
                                ]}
                            >
                                <span class="loc-state">{stateBadge(loc)}</span>
                                <div class="loc-body">
                                    <div class="loc-name">
                                        {loc.shortName}
                                        {loc.status === 'coming-soon' ? (
                                            <span class="loc-coming-soon-tag">Coming Soon</span>
                                        ) : null}
                                    </div>
                                    <div class="loc-address">{formatAddress(loc)}</div>
                                </div>
                                <svg
                                    class="loc-arrow"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                >
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>

        <section class="newsletter-section">
            <div class="newsletter-inner">
                <h2>DON'T MISS A THING</h2>
                <p>
                    Sign up for sneak peeks and early access to new missions, plus special events, ticket drops,
                    and&nbsp;more.
                </p>
                <form name="newsletter" method="POST" action="/contact-thank-you" data-netlify="true" netlify-honeypot="bot-field">
                    <input type="hidden" name="form-name" value="newsletter" />
                    <p class="visually-hidden">
                        <label>
                            Do not fill this out if you are human: <input name="bot-field" />
                        </label>
                    </p>
                    <div class="newsletter-form">
                        <label class="visually-hidden" for="newsletter-given-name">First name</label>
                        <input
                            type="text"
                            id="newsletter-given-name"
                            name="given_name"
                            placeholder="First Name"
                            autocomplete="given-name"
                            required
                        />
                        <label class="visually-hidden" for="newsletter-family-name">Last name</label>
                        <input
                            type="text"
                            id="newsletter-family-name"
                            name="family_name"
                            placeholder="Last Name"
                            autocomplete="family-name"
                        />
                        <label class="visually-hidden" for="newsletter-email">Email</label>
                        <input
                            type="email"
                            id="newsletter-email"
                            name="email"
                            placeholder="Email"
                            class="full-width"
                            autocomplete="email"
                            required
                        />
                    </div>
                    <label class="newsletter-consent">
                        <input type="checkbox" name="marketing_opt_in" value="yes" required />
                        <span>I'd like to receive news, updates, and special offers from Time&nbsp;Mission.</span>
                    </label>
                    <button type="submit" class="btn-subscribe">Sign Up</button>
                    <p class="newsletter-legal">
                        By signing up, you agree to our
                        <a href="/terms">Terms of Service</a>
                        {' '}
                        and
                        {' '}
                        <a href="/privacy">Privacy Policy</a>.
                    </p>
                </form>
            </div>
        </section>
    </main>
</SiteLayout>
