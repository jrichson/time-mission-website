---
import SiteLayout from '../layouts/SiteLayout.astro';
import { allLocations } from '../data/locations';
import phillyCss from '../partials/philadelphia-inline.raw.css.txt?raw';
import phillyMain from '../partials/philadelphia-main.frag.txt?raw';
import phillyAfter from '../partials/philadelphia-after.frag.txt?raw';

const philly = allLocations.find((l) => l.slug === 'philadelphia');
if (!philly) throw new Error('philadelphia missing from src/data/locations');

const ld =
    '{"@context":"https://schema.org","@type":"Organization","name":"Time Mission","url":"https://timemission.com","logo":"https://timemission.com/assets/logo/TM_Favicon.png","sameAs":["https://www.instagram.com/timemission/","https://www.tiktok.com/@timemissionhq","https://www.facebook.com/TimeMissionHQ/"]}';
---

<SiteLayout
    title="Time Mission Philadelphia – 25+ Interactive Mission Rooms"
    description="Teams of 2–5 compete through 25+ immersive missions. Time Mission Philadelphia, book your adventure today."
    canonicalPath="/philadelphia"
    bodyDataLocation={philly.slug}
>
    <Fragment slot="head-extra">
        <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" />
        <link rel="stylesheet" href="/css/footer.css?v=2" />
        <link rel="stylesheet" href="/css/newsletter.css" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
    </Fragment>
    <Fragment slot="page-style">
        <style is:global set:html={phillyCss}></style>
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={phillyMain} />
    <Fragment slot="after-site-scripts" set:html={phillyAfter} />
</SiteLayout>
