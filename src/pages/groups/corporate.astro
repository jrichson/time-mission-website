---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { definePage } from '../../lib/define-page';
import groupEventPageCss from '../../partials/birthdays-inline.raw.css.txt?raw';
import corporateMain from '../../partials/corporate-main.frag.txt?raw';
import groupEventPageAfter from '../../partials/birthdays-after.frag.txt?raw';
import faqs from '../../data/site/faqs.json';
import { buildGroupEventGraph, serializeGraph } from '../../lib/schema/graph';

const faqItems = faqs.sections.find((s) => s.id === 'corporate')?.items ?? [];
const ld = serializeGraph(
    buildGroupEventGraph({
        canonicalPath: '/groups/corporate',
        crumbs: [
            { label: 'Home', href: '/' },
            { label: 'Groups', href: '/groups' },
            { label: 'Corporate Events', href: '/groups/corporate' },
        ],
        serviceName: 'Corporate Event Hosting',
        serviceType: 'BusinessEvent',
        serviceDescription:
            'Corporate team-building events, offsites, and full-venue buyouts at Time Mission with 25+ interactive challenge rooms and head-to-head scoring.',
        faqs: faqItems,
    }),
);
const page = definePage({ canonicalPath: '/groups/corporate' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyClass="has-noise"
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/faq.css?v=3" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
    </Fragment>
    <Fragment slot="page-style">
        <style is:global set:html={groupEventPageCss}></style>
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={corporateMain} />
    <Fragment slot="after-site-scripts" set:html={groupEventPageAfter} />
</SiteLayout>
