---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { definePage } from '../../lib/define-page';
import privateEventsMain from '../../partials/private-events-main.frag.txt?raw';
import faqs from '../../data/site/faqs.json';
import { buildGroupEventGraph, serializeGraph } from '../../lib/schema/graph';

const faqItems = faqs.sections.find((s) => s.id === 'private-events')?.items ?? [];
const ld = serializeGraph(
    buildGroupEventGraph({
        canonicalPath: '/groups/private-events',
        crumbs: [
            { label: 'Home', href: '/' },
            { label: 'Groups', href: '/groups' },
            { label: 'Private Events', href: '/groups/private-events' },
        ],
        serviceName: 'Private Event Hosting',
        serviceType: 'EventVenue',
        serviceDescription:
            'Full-venue buyouts and private events at Time Mission for 40-300+ guests with custom branding, AV coordination, and 25+ interactive missions.',
        faqs: faqItems,
    }),
);
const page = definePage({ canonicalPath: '/groups/private-events' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyClass="has-noise"
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/faq.css?v=3" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
        <link rel="stylesheet" href="/css/page-group-event.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={privateEventsMain} />
    <Fragment slot="after-site-scripts">
        <script defer src="/js/page-group-event-after.js?v=1"></script>
    </Fragment>
</SiteLayout>
