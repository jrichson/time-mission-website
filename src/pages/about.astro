---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import aboutMain from '../partials/about-main.frag.txt?raw';
import aboutFooter from '../partials/about-footer.frag.txt?raw';
import { buildHomeGraph, serializeGraph } from '../lib/schema/graph';

const ld = serializeGraph(buildHomeGraph());
const page = definePage({ canonicalPath: '/about' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/page-about.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={aboutMain} />
    <Fragment slot="footer" set:html={aboutFooter} />
    <Fragment slot="after-site-scripts">
        <script defer src="/js/page-about-after.js?v=1"></script>
    </Fragment>
</SiteLayout>
