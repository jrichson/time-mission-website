---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import { allLocations } from '../data/locations';
import houstonMainRaw from '../partials/houston-main.frag.txt?raw';
import { applyTmMediaBase } from '../lib/tm-media';
import { buildLocationGraph, serializeGraph } from '../lib/schema/graph';

const houston = allLocations.find((l) => l.slug === 'houston');
if (!houston) throw new Error('houston missing from src/data/locations');

const ld = serializeGraph(
    buildLocationGraph('houston', '/houston', [
        { label: 'Home', href: '/' },
        { label: 'Locations', href: '/locations' },
        { label: houston.shortName, href: '/houston' },
    ]),
);
const page = definePage({ canonicalPath: '/houston' });
const houstonMain = applyTmMediaBase(houstonMainRaw);
---

<SiteLayout
    canonicalPath={page.canonicalPath}
    bodyDataLocation={houston.slug}
>
    <Fragment slot="head-extra">
        <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" />
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
        <link rel="stylesheet" href="/css/page-houston.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <div set:html={houstonMain} />
    <Fragment slot="after-site-scripts">
        <script defer src="/js/page-houston-after.js?v=1"></script>
    </Fragment>
</SiteLayout>
