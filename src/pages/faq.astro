---
import SiteLayout from '../layouts/SiteLayout.astro';
import { definePage } from '../lib/define-page';
import Faq from '../components/Faq.astro';
import faqs from '../data/site/faqs.json';
import faqFooter from '../partials/faq-footer.frag.txt?raw';
import { buildFaqGraph, serializeGraph } from '../lib/schema/graph';

const ld = serializeGraph(buildFaqGraph());
const page = definePage({ canonicalPath: '/faq' });
---

<SiteLayout
    canonicalPath={page.canonicalPath}
>
    <Fragment slot="head-extra">
        <link rel="stylesheet" href="/css/footer.css?v=3" />
        <link rel="stylesheet" href="/css/newsletter.css?v=2" />
        <link rel="stylesheet" href="/css/faq.css?v=3" />
        <link rel="stylesheet" href="/css/ticket-panel.css" />
        <link rel="stylesheet" href="/css/page-faq.css?v=1" />
    </Fragment>
    <Fragment slot="json-ld">
        <script type="application/ld+json" is:inline set:html={ld}></script>
    </Fragment>
    <Fragment slot="footer" set:html={faqFooter} />

    <main class="faq-main">
        <section class="page-header">
            <div class="reveal">
                <div class="section-badge">Got Questions?</div>
                <h1 class="section-title">FREQUENTLY ASKED QUESTIONS</h1>
                <p class="page-subtitle">
                    Everything you need to know before your Time Mission adventure. Can't find what you're looking for?
                    Contact us directly.
                </p>
            </div>
        </section>
        {
            faqs.sections.map((section) => (
                <section class="faq-section" id={section.id}>
                    <Faq heading={section.heading} items={section.items} />
                </section>
            ))
        }

        <section class="cta-section">
            <div class="cta-content reveal">
                <h2 class="cta-title">STILL HAVE QUESTIONS?</h2>
                <p class="cta-text">Can't find what you're looking for? We're happy to help.</p>
                <a href="mailto:info@lolcommandcenter.com" class="btn-primary">
                    Contact Us
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </section>

        <section class="newsletter-section">
            <div class="newsletter-inner">
                <h2>DON'T MISS A THING</h2>
                <p>Sign up for sneak peeks and early access to new missions, plus special events, ticket drops, and&nbsp;more.</p>
                <form name="newsletter" method="POST" action="/contact-thank-you" data-netlify="true" netlify-honeypot="bot-field">
                    <input type="hidden" name="form-name" value="newsletter" />
                    <p class="visually-hidden">
                        <label>
                            Do not fill this out if you are human: <input name="bot-field" />
                        </label>
                    </p>
                    <div class="newsletter-form">
                        <label class="visually-hidden" for="newsletter-given-name">First name</label>
                        <input
                            type="text"
                            id="newsletter-given-name"
                            name="given_name"
                            placeholder="First Name"
                            autocomplete="given-name"
                            required
                        />
                        <label class="visually-hidden" for="newsletter-family-name">Last name</label>
                        <input
                            type="text"
                            id="newsletter-family-name"
                            name="family_name"
                            placeholder="Last Name"
                            autocomplete="family-name"
                        />
                        <label class="visually-hidden" for="newsletter-email">Email</label>
                        <input
                            type="email"
                            id="newsletter-email"
                            name="email"
                            placeholder="Email"
                            class="full-width"
                            autocomplete="email"
                            required
                        />
                    </div>
                    <label class="newsletter-consent">
                        <input type="checkbox" name="marketing_opt_in" value="yes" required />
                        <span>I'd like to receive news, updates, and special offers from Time&nbsp;Mission.</span>
                    </label>
                    <button type="submit" class="btn-subscribe">Sign Up</button>
                    <p class="newsletter-legal">
                        By signing up, you agree to our
                        <a href="/terms">Terms of Service</a>
                        {' '}
                        and
                        {' '}
                        <a href="/privacy">Privacy Policy</a>.
                    </p>
                </form>
            </div>
        </section>
    </main>

    <Fragment slot="after-site-scripts">
        <script defer src="/js/page-faq-after.js?v=1"></script>
    </Fragment>
</SiteLayout>
