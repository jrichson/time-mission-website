---
import SiteHead from '../components/SiteHead.astro';
import { definePage } from '../lib/define-page';

const page = definePage({ canonicalPath: '/contact-thank-you' });
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <SiteHead canonicalPath={page.canonicalPath} />
        <style is:global>
            body {
                min-height: 100vh;
                display: grid;
                place-items: center;
                padding: 2rem;
                background:
                    radial-gradient(circle at 20% 20%, rgba(255, 107, 44, 0.18), transparent 32rem),
                    radial-gradient(circle at 80% 10%, rgba(0, 229, 255, 0.12), transparent 28rem),
                    var(--black);
            }

            .thank-you-card {
                max-width: 620px;
                padding: clamp(2rem, 5vw, 4rem);
                border: 1px solid rgba(255, 107, 44, 0.24);
                border-radius: 24px;
                background: rgba(21, 21, 21, 0.86);
                text-align: center;
                box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
            }

            .thank-you-card h1 {
                font-family: var(--display);
                font-size: clamp(3rem, 10vw, 6rem);
                line-height: 0.9;
                letter-spacing: 0.02em;
                margin-bottom: 1rem;
            }

            .thank-you-card p {
                color: var(--gray);
                line-height: 1.7;
                margin-bottom: 2rem;
            }

            .thank-you-card a {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0.9rem 1.4rem;
                border-radius: 999px;
                background: var(--gradient-primary);
                color: var(--white);
                font-weight: 700;
                text-decoration: none;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }
        </style>
    </head>
    <body>
        <main class="thank-you-card">
            <h1>Message Sent</h1>
            <p>
                Thanks for reaching out. The Time Mission team received your message and will get back to you within
                24-48 hours.
            </p>
            <a href="/">Back to Home</a>
        </main>
        <script defer is:inline src="/js/consent-bridge.js?v=1"></script>
        <script is:inline src="/js/analytics.js?v=1"></script>
        <script is:inline src="/js/contact-form-analytics.js?v=1"></script>
        <script defer is:inline src="/js/a11y.js"></script>
    </body>
</html>
